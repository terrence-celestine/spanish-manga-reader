# Neon (or any Postgres) connection string.
# Neon: copy the "pooled" connection string from your project dashboard.
# It already contains ?sslmode=require, which enables SSL automatically.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Port the API/static server listens on (Railway sets PORT automatically).
PORT=8080
